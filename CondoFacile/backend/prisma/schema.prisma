// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Condominio {
  id            Int             @id @default(autoincrement())
  nome          String
  indirizzo     String
  createdAt     DateTime        @default(now())
  condomini     Condomino[]
  ticket        Ticket[]
  scadenze      Scadenza[]
  comunicazioni Comunicazione[]
  lavori        Lavoro[]
  quote         QuotaMensile[]
  assemblee     Assemblea[]
  documenti     Documento[]
  fornitori     Fornitore[]
}

model Condomino {
  id           Int              @id @default(autoincrement())
  nome         String
  cognome      String
  email        String?
  telefono     String?
  unita        String
  millesimi    Float            @default(0)
  tipo         String           @default("proprietario")
  stato        String           @default("attivo")
  condominioId Int
  condominio   Condominio       @relation(fields: [condominioId], references: [id])
  pagamenti     PagamentoQuota[]
  ticketsAperti        Ticket[]               @relation("TicketAperti")
  lettureComunicazioni ComunicazioneLettura[] @relation("LettureComunicazioni")
  presenzeAssemblee    AssembleaPresenza[]    @relation("PresenzeAssemblee")
  user                 User?
  votiAssemblea        AssembleaVoto[]
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  role         String     @default("CONDOMINO")
  condominoId  Int?       @unique
  condomino    Condomino? @relation(fields: [condominoId], references: [id])
  profilePhoto String?
  createdAt    DateTime   @default(now())
}

model QuotaMensile {
  id            Int              @id @default(autoincrement())
  mese          Int
  anno          Int
  importoTotale Float
  condominioId  Int
  condominio    Condominio       @relation(fields: [condominioId], references: [id])
  pagamenti     PagamentoQuota[]
}

model PagamentoQuota {
  id               Int          @id @default(autoincrement())
  importo          Float
  dataPagamento    DateTime?
  stato            String       @default("in_attesa")
  metodoPagamento  String?
  note             String?
  condominoId      Int
  condomino        Condomino    @relation(fields: [condominoId], references: [id])
  quotaId          Int
  quota            QuotaMensile @relation(fields: [quotaId], references: [id])
}

model Ticket {
  id                  Int          @id @default(autoincrement())
  titolo              String
  descrizione         String       @default("")
  categoria           String
  priorita            String       @default("media")
  stato               String       @default("Nuova")
  foto                String?
  assegnatoa          String?
  fornitoreId         Int?
  fornitore           Fornitore?   @relation(fields: [fornitoreId], references: [id])
  dataApertura        DateTime     @default(now())
  dataChiusura        DateTime?
  condominioId        Int
  interventi          Intervento[]
  condominio          Condominio   @relation(fields: [condominioId], references: [id])
  apertoCondominoId   Int?
  apertoCondomino     Condomino?   @relation("TicketAperti", fields: [apertoCondominoId], references: [id])
  note                TicketNota[]
}

model TicketNota {
  id        Int      @id @default(autoincrement())
  testo     String
  autore    String
  createdAt DateTime @default(now())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Scadenza {
  id           Int        @id @default(autoincrement())
  descrizione  String
  data         DateTime
  tipo         String
  condominioId Int
  condominio   Condominio @relation(fields: [condominioId], references: [id])
}

model Comunicazione {
  id               Int                    @id @default(autoincrement())
  titolo           String
  corpo            String                 @default("")
  tipo             String
  data             DateTime               @default(now())
  destinatari      Int                    @default(0)
  destinatariTipo  String                 @default("tutti")
  condominioId     Int
  condominio       Condominio             @relation(fields: [condominioId], references: [id])
  letture          ComunicazioneLettura[]
}

model ComunicazioneLettura {
  id               Int           @id @default(autoincrement())
  comunicazioneId  Int
  comunicazione    Comunicazione @relation(fields: [comunicazioneId], references: [id], onDelete: Cascade)
  condominoId      Int
  condomino        Condomino     @relation("LettureComunicazioni", fields: [condominoId], references: [id])
  dataLettura      DateTime      @default(now())

  @@unique([comunicazioneId, condominoId])
}

model Lavoro {
  id           Int        @id @default(autoincrement())
  descrizione  String
  fornitore    String
  dataInizio   DateTime
  dataFine     DateTime
  stato        String     @default("In corso")
  progressione Int        @default(0)
  condominioId Int
  condominio   Condominio @relation(fields: [condominioId], references: [id])
}

model Fornitore {
  id           Int         @id @default(autoincrement())
  nome         String
  tipo         String      @default("generico")
  email        String?
  telefono     String?
  indirizzo    String?
  note         String?
  condominioId Int?
  condominio   Condominio? @relation(fields: [condominioId], references: [id])
  interventi   Intervento[]
  tickets      Ticket[]
}

model Intervento {
  id          Int        @id @default(autoincrement())
  fornitoreId Int
  fornitore   Fornitore  @relation(fields: [fornitoreId], references: [id], onDelete: Cascade)
  ticketId    Int?
  ticket      Ticket?    @relation(fields: [ticketId], references: [id])
  descrizione String
  data        DateTime   @default(now())
  costo       Float?     
  createdAt   DateTime   @default(now())
}

model Assemblea {
  id               Int                  @id @default(autoincrement())
  titolo           String
  data             DateTime
  luogo            String               @default("")
  tipo             String               @default("ordinaria") // "ordinaria" | "straordinaria"
  stato            String               @default("convocata") // "convocata" | "in_corso" | "conclusa" | "annullata"
  ordineDelGiorno  String               @default("")
  verbale          String?
  condominioId     Int
  condominio       Condominio           @relation(fields: [condominioId], references: [id])
  presenze         AssembleaPresenza[]
  puntiOdG         AssembleaPuntoOdG[]
}

model AssembleaPresenza {
  id          Int       @id @default(autoincrement())
  assembleaId Int
  assemblea   Assemblea @relation(fields: [assembleaId], references: [id], onDelete: Cascade)
  condominoId Int
  condomino   Condomino @relation("PresenzeAssemblee", fields: [condominoId], references: [id])
  presente    Boolean   @default(false)
  delegatoId  Int?      // condominoId del delegato che lo rappresenta

  @@unique([assembleaId, condominoId])
}

model AssembleaPuntoOdG {
  id          Int       @id @default(autoincrement())
  assembleaId Int
  assemblea   Assemblea @relation(fields: [assembleaId], references: [id], onDelete: Cascade)
  titolo      String
  descrizione String    @default("")
  ordine      Int       @default(0)
  esito       String?   // "approvato" | "respinto" | "rimandato"
  votiSi      Float     @default(0)
  votiNo      Float     @default(0)
  votiAstenuti Float    @default(0)
  voti        AssembleaVoto[]
}

model AssembleaVoto {
  id          Int                  @id @default(autoincrement())
  puntoOdGId  Int
  punto       AssembleaPuntoOdG    @relation(fields: [puntoOdGId], references: [id], onDelete: Cascade)
  condominoId Int
  condomino   Condomino            @relation(fields: [condominoId], references: [id])
  scelta      String               // 'si' | 'no' | 'astenuto'
  createdAt   DateTime             @default(now())

  @@unique([puntoOdGId, condominoId])
}

model Documento {
  id           Int        @id @default(autoincrement())
  nome         String
  categoria    String     // regolamento | verbali | fatture_pagamenti | contratti | certificazioni | polizze | planimetrie
  tag          String     @default("")
  visibilita   String     @default("pubblica") // pubblica | privata | selettiva
  unitaAccesso String     @default("") // comma-separated unit numbers when visibilita = selettiva
  filePath     String
  fileSize     Int
  mimeType     String
  versione     Int        @default(1)
  condominioId Int
  condominio   Condominio @relation(fields: [condominioId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

